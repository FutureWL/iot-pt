# ============================================================
# IoT Platform - 环境变量模板
#
# 使用方式:
#   开发环境: cp .env.example .env.dev     (可提交到仓库)
#   生产环境: cp .env.example .env.prod    (必须修改所有密码!)
#
# 启动命令:
#   dev:  docker compose -f docker-compose.yml -f docker-compose.dev.yml  --env-file .env.dev  up -d
#   prod: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# 应用版本(影响镜像 tag)
APP_VERSION=1.0.0

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DB=iot_platform
MYSQL_USER=iot
MYSQL_PASSWORD=CHANGE_ME_iot_password
MYSQL_PORT=33402

# ---------- TDengine ----------
TDENGINE_PORT=33403
TDENGINE_NATIVE_PORT=33404

# ---------- EMQX ----------
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_emqx_dashboard
EMQX_MQTT_PORT=33405
EMQX_MQTTS_PORT=33406
EMQX_WS_PORT=33407
EMQX_WSS_PORT=33408
EMQX_DASHBOARD_PORT=33409

# MQTT 业务账号(在 EMQX Dashboard 里创建,后端用此连接)
MQTT_USERNAME=CHANGE_ME_mqtt_user
MQTT_PASSWORD=CHANGE_ME_mqtt_password

# ---------- Backend ----------
BACKEND_PORT=33412
TCP_PORT=33410
# 必须 ≥32 字节,推荐: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_bytes_long

# ---------- Frontend ----------
FRONTEND_PORT=33411

# ---------- Spring Profile ----------
# dev:  详细日志 + SQL 输出
# prod: WARN 级别,精简输出
SPRING_PROFILES_ACTIVE=prod

# ---------- 前端构建参数 ----------
# 留空 = 同源,走 Nginx 反代到 backend
# dev 也可以留空(nginx.conf 已配 /api 反代)
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
VITE_APP_TITLE=物联网平台