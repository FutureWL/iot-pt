# ============================================================
# IoT Platform - 部署环境变量
# 端口规划: 全部从 33400 起算,避免和本机其他服务冲突
#   33400 - (被 pi-node 占用,跳过)
#   33401 - (被 pi-node 占用,跳过)
#   33402 - MySQL
#   33403 - TDengine RESTful
#   33404 - TDengine Native(容器内)
#   33405 - MQTT TCP
#   33406 - MQTT SSL
#   33407 - MQTT WebSocket
#   33408 - MQTT WSS
#   33409 - EMQX Dashboard
#   33410 - TCP Server(后端内嵌)
#   33411 - Frontend
#   33412 - Backend API
# ============================================================

# MySQL
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DB=iot_platform
MYSQL_USER=iot
MYSQL_PASSWORD=iot123456
MYSQL_PORT=33402

# TDengine
TDENGINE_PORT=33403
TDENGINE_NATIVE_PORT=33404

# EMQX
EMQX_DASHBOARD_PASSWORD=public
EMQX_MQTT_PORT=33405
EMQX_MQTTS_PORT=33406
EMQX_WS_PORT=33407
EMQX_WSS_PORT=33408
EMQX_DASHBOARD_PORT=33409

# MQTT 业务账号(在 EMQX Dashboard 里创建,后端用此连接)
MQTT_USERNAME=emqx_user
MQTT_PASSWORD=emqx_pass

# 后端
BACKEND_PORT=33412
TCP_PORT=33410
JWT_SECRET=iot-platform-super-secret-key-must-be-at-least-32-bytes-long-for-hs256

# 前端
FRONTEND_PORT=33411
