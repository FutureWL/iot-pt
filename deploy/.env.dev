# ============================================================
# IoT Platform - 开发环境变量(可提交到仓库,值是安全默认值)
# 使用: docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up -d
# ============================================================

# 镜像版本(dev 用 latest,便于本地 build)
APP_VERSION=dev

# MySQL
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DB=iot_platform
MYSQL_USER=iot
MYSQL_PASSWORD=iot123456
MYSQL_PORT=33402

# TDengine(默认无密码)
TDENGINE_PORT=33403
TDENGINE_NATIVE_PORT=33404

# EMQX
EMQX_DASHBOARD_PASSWORD=public
EMQX_MQTT_PORT=33405
EMQX_MQTTS_PORT=33406
EMQX_WS_PORT=33407
EMQX_WSS_PORT=33408
EMQX_DASHBOARD_PORT=33409

# MQTT 业务账号(在 EMQX Dashboard 里创建,后端用此连接)
MQTT_USERNAME=emqx_user
MQTT_PASSWORD=emqx_pass

# 后端
BACKEND_PORT=33412
TCP_PORT=33410
# dev 可使用默认 secret,prod 必须改成随机强密码
JWT_SECRET=iot-platform-dev-secret-key-must-be-at-least-32-bytes-long-for-hs256

# 前端
FRONTEND_PORT=33411

# 后端 Spring Profile(dev 启用 DEBUG 日志和 SQL 输出)
SPRING_PROFILES_ACTIVE=dev

# 前端构建参数(dev 用相对路径走 Nginx → backend 反代)
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
VITE_APP_TITLE=物联网平台 (Dev)