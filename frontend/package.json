{
  "name": "iot-platform-frontend",
  "version": "1.0.0",
  "description": "IoT Platform Frontend (Vue 3 + Vite + TS + Element Plus)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest run --reporter=verbose",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install --with-deps chromium",
    "verify": "npm run type-check && npm run test:run && npm run e2e"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.7",
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "element-plus": "^2.8.7",
    "js-cookie": "^3.0.5",
    "mitt": "^3.0.1",
    "mqtt": "^5.15.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.12",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.9.0",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^14.12.0",
    "sass": "^1.80.6",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^0.18.5",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^5.4.10",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.1.10"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  }
}
