# API 基础地址(开发环境,Vite 会代理)
# 后端端口: 容器 9000 → 主机 ${BACKEND_PORT:-33412}
# 端口规则: 33400/33401 被 pi-node 占用,跳过;Backend API 用 33412
VITE_API_BASE_URL=http://localhost:33412/api

# WebSocket 地址(实时数据/告警推送)
VITE_WS_BASE_URL=ws://localhost:33412/api/ws

# 应用标题
VITE_APP_TITLE=物联网平台

# 高德地图 JS API Key(留空则 GIS 页面用占位)
# 申请: https://console.amap.com/dev/key/app → 创建应用 → 添加 Key(选 Web 端 JS API)
VITE_AMAP_KEY=

# 可选: 高德安全密钥(v2.0+ 服务接口必需,如搜索/逆地理)
VITE_AMAP_SECURITY_CODE=
