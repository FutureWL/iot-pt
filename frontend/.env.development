# ============================================================
# 前端 - 开发环境 (npm run dev 自动加载)
# ============================================================

# 用相对路径,Vite dev server 会把 /api 代理到 vite.config.ts 里配置的 target
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/api/ws
VITE_APP_TITLE=物联网平台 (Dev)
VITE_BUILD_TIME=dev