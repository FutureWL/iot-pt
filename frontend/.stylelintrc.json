{
  "extends": ["stylelint-config-standard-scss"],
  "plugins": [],
  "rules": {
    "no-descending-specificity": null,
    "selector-class-pattern": null,
    "scss/at-import-partial-extension": null,
    "scss/at-use-no-unnamespaced": null,
    "scss/dollar-variable-pattern": null,
    "scss/load-no-partial-leading-underscore": null,
    "scss/no-global-function-names": null,
    "selector-pseudo-element-no-unknown": [true, { "ignorePseudoElements": ["deep", "global", "slotted"] }],
    "value-keyword-case": null,
    "media-feature-range-notation": null,
    "alpha-value-notation": null,
    "color-function-notation": null,
    "selector-not-notation": null,
    "shorthand-property-no-redundant-values": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "no-empty-source": null,
    "scss/comment-no-empty": null,
    "no-duplicate-selectors": null,
    "no-invalid-position-at-import-rule": null,
    "scss/at-extend-no-missing-placeholder": null,
    "scss/at-if-no-null": null,
    "comment-empty-line-before": null,
    "rule-empty-line-before": null,
    "declaration-empty-line-before": null,
    "at-rule-empty-line-before": null,
    "scss/double-slash-comment-empty-line-before": null,
    "scss/double-slash-comment-whitespace-inside": null,
    "scss/dollar-variable-colon-space-after": null,
    "scss/dollar-variable-colon-space-before": null,
    "scss/dollar-variable-empty-line-before": null,
    "declaration-block-single-line-max-declarations": null,
    "scss/at-mixin-argumentless-call-parentheses": null,
    "scss/no-duplicate-mixins": null,
    "selector-pseudo-class-no-unknown": [true, { "ignorePseudoClasses": ["deep", "global"] }],
    "scss/no-unused-private-members": null,
    "number-max-precision": null,
    "declaration-block-no-shorthand-property-overrides": null,
    "property-no-vendor-prefix": null,
    "value-no-vendor-prefix": null,
    "selector-no-vendor-prefix": null,
    "media-feature-name-no-vendor-prefix": null,
    "keyframes-name-pattern": null,
    "scss/at-mixin-pattern": null,
    "scss/at-function-pattern": null,
    "scss/percent-placeholder-pattern": null,
    "function-no-unknown": [true, { "ignoreFunctions": ["v-bind"] }],
    "color-hex-length": null,
    "custom-property-empty-line-before": null,
    "scss/at-rule-no-unknown": [true, { "ignoreAtRules": ["apply", "use", "forward", "include", "mixin", "if", "else", "for", "each", "while", "function", "return", "extend", "debug", "warn", "error"] }]
  },
  "ignoreFiles": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "**/*.vue"
  ]
}
