# ============================================================
# IoT Platform - Git Ignore
# ============================================================

# ===== Java / Maven =====
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
.mvn/wrapper/maven-wrapper.jar
build/
out/

# ===== Python (设备模拟器)=====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
ENV/
.mypy_cache/
.ruff_cache/

# ===== IDE =====
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/
.factorypath

# ===== Node / Vue =====
node_modules/
dist/
dist-ssr/
dist-story/
.histoire/dist/
*.local
.pnpm-store/

# ===== 测试产物(Vitest + Playwright)=====
coverage/
playwright-report/
test-results/
.nyc_output/
*.lcov

# ===== 日志 =====
logs/
*.log

# ===== 环境变量 =====
# 默认忽略所有 .env 真值文件,只保留示例文件
.env
.env.local
.env.*.local

# 部署环境变量(只保留示例)
deploy/.env
deploy/.env.prod
deploy/.env.local

# 前端环境变量(只保留 dev/prod 示例)
frontend/.env.local
frontend/.env.*.local

# 保留 .env.example / .env.dev / .env.production
!.env.example
!frontend/.env.example
!frontend/.env.development
!frontend/.env.production
!deploy/.env.example
!deploy/.env.dev

# ===== 上传 / 临时文件 =====
uploadPath/
tmp/
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db

# ===== Docker volume 数据(部署时挂载)=====
deploy/mysql/data/
deploy/tdengine/data/
deploy/emqx/data/
deploy/emqx/log/

# ===== 构建产物 =====
deploy/.build/

# ===== 客户文档(敏感,不入版本控制)=====
# 客户需求文档涉及真实客户信息(国网专项等),
# 本地保留但不提交,改用私有仓库或加密备份
customer-requirements/

# ============================================================
# 注意:以下目录 **不** 忽略,显式纳入版本控制:
#   - tools/                 工具集(设备模拟器等)
#   - frontend/tests/        前端测试套件
#   - frontend/playwright.config.ts
# ============================================================
# IoT 多模块临时文件
/tmp/iot-api*.log
/tmp/iot-broker*.log

# ===== Playwright 产物 (不入库) =====
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/playwright/.cache/

# ===== Prometheus / Grafana 临时数据 =====
deploy/prometheus_data/
deploy/grafana_data/

# ===== IDE / OS =====
.vscode/
.idea/
.DS_Store
*.swp
*.swo
